# AWP scanner configuration.
# Copy to ".env" and fill in. Never commit the real .env.

# Shared secret the AWP Worker must send as `Authorization: Bearer <SCAN_TOKEN>`.
# Generate a long random value:  openssl rand -hex 24
SCAN_TOKEN=replace-with-a-long-random-secret

# Port the HTTP server listens on (Cloudflare Tunnel points here). Default 8080.
PORT=8080
