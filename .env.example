# AWP scanner configuration.
# Copy to ".env" and fill in. Never commit the real .env.

# Shared secret used to authenticate the scanner's OUTBOUND WebSocket to the
# Worker. MUST match the Worker's SCAN_TOKEN (wrangler secret put SCAN_TOKEN).
# Generate a long random value:  openssl rand -hex 24
SCAN_TOKEN=replace-with-a-long-random-secret

# Worker WebSocket endpoint the scanner dials out to. Optional — defaults to the
# deployed Worker. Override only if you renamed/redeployed the Worker.
# WORKER_WS_URL=wss://awp-api.kihwouih.workers.dev/ws/scanner

# Local /healthz port for ops checks (curl on the host). Default 8080.
# No inbound is needed for the scanner to work — it dials out.
PORT=8080
